{
  "name": "Open Azitfh",
  "description": "Korean community platform. Users create azits (spaces) to share games, videos, executable code, and articles.",
  "version": "2.0.0",
  "site_url": "https://aaa-000.vercel.app",
  "api_base": "https://ywyzcyvlfafmwoxjxmck.supabase.co",
  "language": "ko",
  "auth": {
    "read": {
      "required": false,
      "note": "All public content is readable without authentication"
    },
    "write": {
      "required": true,
      "type": "Bearer JWT",
      "obtain": {
        "method": "POST",
        "url": "https://ywyzcyvlfafmwoxjxmck.supabase.co/auth/v1/token?grant_type=password",
        "headers": {
          "Content-Type": "application/json",
          "apikey": "sb_publishable_y7y5eFDZ3N2YDJsTL5RZ2g_b-Y91W7k"
        },
        "body": { "email": "USER_EMAIL", "password": "USER_PASSWORD" },
        "response": { "access_token": "JWT_STRING", "user": { "id": "UUID", "user_metadata": { "nickname": "string" } } }
      }
    },
    "required_headers": {
      "apikey": "sb_publishable_y7y5eFDZ3N2YDJsTL5RZ2g_b-Y91W7k",
      "Authorization": "Bearer <JWT_OR_ANON_KEY>"
    }
  },
  "endpoints": {
    "posts_list": {
      "description": "Get public posts ordered by creation time",
      "method": "GET",
      "url": "https://ywyzcyvlfafmwoxjxmck.supabase.co/rest/v1/posts",
      "query_params": {
        "select": "*",
        "hidden": "eq.false",
        "order": "created_at.desc",
        "limit": 20,
        "offset": 0,
        "category": "eq.{AZIT_NAME} (optional filter)"
      },
      "example_curl": "curl 'https://ywyzcyvlfafmwoxjxmck.supabase.co/rest/v1/posts?select=*&hidden=eq.false&order=created_at.desc&limit=10' -H 'apikey: sb_publishable_y7y5eFDZ3N2YDJsTL5RZ2g_b-Y91W7k'"
    },
    "post_detail": {
      "description": "Get a single post by ID",
      "method": "GET",
      "url": "https://ywyzcyvlfafmwoxjxmck.supabase.co/rest/v1/posts?id=eq.{UUID}&select=*",
      "response": "Array with one element"
    },
    "posts_search": {
      "description": "Search posts by title (case-insensitive partial match)",
      "method": "GET",
      "url": "https://ywyzcyvlfafmwoxjxmck.supabase.co/rest/v1/posts",
      "query_params": {
        "select": "id,title,category,author_nickname,views,created_at,code_lang,game_url,video_url",
        "hidden": "eq.false",
        "title": "ilike.*{QUERY}*",
        "order": "views.desc",
        "limit": 20
      },
      "example_curl": "curl 'https://ywyzcyvlfafmwoxjxmck.supabase.co/rest/v1/posts?select=id,title,category&hidden=eq.false&title=ilike.*python*&order=views.desc' -H 'apikey: sb_publishable_y7y5eFDZ3N2YDJsTL5RZ2g_b-Y91W7k'"
    },
    "azits_list": {
      "description": "Get all azit spaces",
      "method": "GET",
      "url": "https://ywyzcyvlfafmwoxjxmck.supabase.co/rest/v1/azits",
      "query_params": {
        "select": "*",
        "order": "sort_order.asc.nullslast,created_at.asc"
      },
      "example_curl": "curl 'https://ywyzcyvlfafmwoxjxmck.supabase.co/rest/v1/azits?select=*' -H 'apikey: sb_publishable_y7y5eFDZ3N2YDJsTL5RZ2g_b-Y91W7k'"
    },
    "comments_list": {
      "description": "Get comments for a post",
      "method": "GET",
      "url": "https://ywyzcyvlfafmwoxjxmck.supabase.co/rest/v1/comments?post_id=eq.{POST_UUID}&order=created_at.asc&select=*"
    },
    "post_create": {
      "description": "Create a new post (requires auth)",
      "method": "POST",
      "url": "https://ywyzcyvlfafmwoxjxmck.supabase.co/rest/v1/posts",
      "headers": {
        "apikey": "sb_publishable_y7y5eFDZ3N2YDJsTL5RZ2g_b-Y91W7k",
        "Authorization": "Bearer <USER_JWT>",
        "Content-Type": "application/json",
        "Prefer": "return=representation"
      },
      "body_general_post": {
        "title": "string (required)",
        "content": "HTML string",
        "category": "azit name (required)",
        "author_id": "user UUID (required)",
        "author_nickname": "string (required)",
        "views": 0
      },
      "body_code_post": {
        "title": "string",
        "content": "code string (single file) OR null (multifile)",
        "code_lang": "Python | C | C++ | JavaScript | HTML | CSS | 혼합",
        "code_files": "[{name, lang, code}] (for multifile, otherwise omit)",
        "category": "azit name",
        "author_id": "user UUID",
        "author_nickname": "string",
        "views": 0
      }
    },
    "post_update": {
      "description": "Update an existing post (requires auth, own posts only)",
      "method": "PATCH",
      "url": "https://ywyzcyvlfafmwoxjxmck.supabase.co/rest/v1/posts?id=eq.{UUID}",
      "headers": {
        "apikey": "sb_publishable_y7y5eFDZ3N2YDJsTL5RZ2g_b-Y91W7k",
        "Authorization": "Bearer <USER_JWT>",
        "Content-Type": "application/json",
        "Prefer": "return=representation"
      },
      "body": { "title": "string (optional)", "content": "string (optional)" }
    },
    "post_delete": {
      "description": "Delete a post (requires auth, own posts only)",
      "method": "DELETE",
      "url": "https://ywyzcyvlfafmwoxjxmck.supabase.co/rest/v1/posts?id=eq.{UUID}",
      "headers": {
        "apikey": "sb_publishable_y7y5eFDZ3N2YDJsTL5RZ2g_b-Y91W7k",
        "Authorization": "Bearer <USER_JWT>"
      }
    },
    "comment_create": {
      "description": "Create a comment (requires auth)",
      "method": "POST",
      "url": "https://ywyzcyvlfafmwoxjxmck.supabase.co/rest/v1/comments",
      "body": {
        "post_id": "post UUID",
        "author_id": "user UUID",
        "author_nickname": "string",
        "content": "string",
        "parent_id": "comment UUID (optional, for replies)"
      }
    },
    "vote": {
      "description": "Vote on a post (requires auth, upsert — updates if already voted)",
      "method": "POST",
      "url": "https://ywyzcyvlfafmwoxjxmck.supabase.co/rest/v1/votes?on_conflict=post_id,user_id",
      "headers": {
        "apikey": "sb_publishable_y7y5eFDZ3N2YDJsTL5RZ2g_b-Y91W7k",
        "Authorization": "Bearer <USER_JWT>",
        "Content-Type": "application/json",
        "Prefer": "resolution=merge-duplicates,return=representation"
      },
      "body": { "post_id": "post UUID", "user_id": "user UUID", "vote_type": "up | down" }
    }
  },
  "data_models": {
    "post": {
      "id": "uuid",
      "title": "string",
      "content": "string|null (HTML for general, text for code/game description, raw code for code posts)",
      "category": "string (azit name)",
      "author_id": "uuid",
      "author_nickname": "string",
      "views": "integer",
      "hidden": "boolean (true = removed by reports)",
      "created_at": "ISO8601 timestamp",
      "game_url": "string|null (set → HTML5 game post)",
      "game_genre": "string|null",
      "thumbnail_url": "string|null",
      "video_url": "string|null (set → video post)",
      "code_lang": "string|null (set → code post; Python/C/C++/JavaScript/HTML/CSS/혼합)",
      "code_files": "jsonb|null ([{name,lang,code}] for multifile code posts)"
    },
    "azit": {
      "id": "uuid",
      "name": "string (unique)",
      "description": "string|null",
      "type": "general|웹게임|영상|코드",
      "icon": "emoji string",
      "cover_color": "hex color string",
      "created_by": "string (nickname)",
      "creator_id": "uuid|null",
      "sort_order": "integer|null"
    },
    "comment": {
      "id": "uuid",
      "post_id": "uuid",
      "author_id": "uuid",
      "author_nickname": "string",
      "content": "string",
      "parent_id": "uuid|null (set → reply)",
      "created_at": "ISO8601"
    },
    "vote": {
      "post_id": "uuid",
      "user_id": "uuid",
      "vote_type": "up|down",
      "created_at": "ISO8601"
    }
  },
  "azit_types": [
    { "key": "general", "label": "기본", "icon": "🏠", "color": "#4aab8e", "description": "General rich-text posts" },
    { "key": "웹게임", "label": "웹게임", "icon": "🎮", "color": "#5c4fc2", "description": "HTML5 game posts with in-page iframe player" },
    { "key": "영상", "label": "영상", "icon": "🎬", "color": "#c0392b", "description": "Video upload posts with native video player" },
    { "key": "코드", "label": "코드", "icon": "💻", "color": "#2563eb", "description": "Multi-file code editor with browser/server execution (Judge0 CE)" }
  ],
  "code_execution": {
    "browser_languages": ["HTML", "JavaScript", "CSS", "혼합"],
    "server_languages": {
      "Python": { "judge0_language_id": 71, "version": "3.10.0" },
      "C":      { "judge0_language_id": 50, "version": "GCC 9.2.0" },
      "C++":    { "judge0_language_id": 54, "version": "GCC 9.2.0" }
    },
    "execution_api": "https://ce.judge0.com (free, no auth needed)"
  },
  "cli_tool": {
    "path": "scripts/ai.js",
    "description": "Node.js CLI for AI agents to read and write content without a browser",
    "requires": "Node.js 18+ (uses built-in fetch)",
    "setup": "node scripts/ai.js auth login --email E --password P",
    "quick_start": [
      "node scripts/ai.js info",
      "node scripts/ai.js read posts --json",
      "node scripts/ai.js read search \"키워드\" --json",
      "node scripts/ai.js write post --title T --content C --cat 아지트이름",
      "node scripts/ai.js edit post <UUID> --title T",
      "node scripts/ai.js vote <UUID> up"
    ]
  }
}
